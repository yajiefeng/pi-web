{
  "name": "@agegr/pi-web",
  "version": "0.7.4",
  "description": "Web UI for the pi coding agent",
  "homepage": "https://github.com/agegr/pi-web#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agegr/pi-web.git"
  },
  "bugs": {
    "url": "https://github.com/agegr/pi-web/issues"
  },
  "license": "MIT",
  "bin": {
    "pi-web": "bin/pi-web.js",
    "pi-web-rpc-bridge": "bin/pi-web-rpc-bridge.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 30141",
    "build": "next build --webpack",
    "start": "next start -p 30141",
    "lint": "eslint .",
    "test:auth-providers": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-auth-providers.mjs",
    "test:herdr-agent-creation": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-herdr-agent-creation.mjs",
    "test:herdr-bridge-routing": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-herdr-bridge-routing.mjs",
    "test:herdr-bridge-ui": "node scripts/check-herdr-bridge-ui.mjs",
    "test:herdr-pending-ui": "node scripts/check-herdr-pending-ui.mjs",
    "test:herdr-pending-resolution": "node scripts/check-herdr-pending-resolution.mjs",
    "test:herdr-pending-timeout": "node scripts/check-herdr-pending-timeout.mjs",
    "test:herdr-readonly-ui": "node scripts/check-herdr-readonly-ui.mjs",
    "test:herdr-web-fallback": "node scripts/check-herdr-web-fallback.mjs",
    "test:herdr-mobile-acceptance": "node scripts/check-herdr-mobile-acceptance.mjs",
    "test:herdr-rpc-bridge-architecture": "node scripts/check-herdr-rpc-bridge-architecture.mjs",
    "test:mobile-input-font-size": "node scripts/check-mobile-input-font-size.mjs",
    "test:pi-web-rpc-bridge": "node scripts/check-pi-web-rpc-bridge.mjs",
    "test:runtime-status": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-runtime-status.mjs",
    "test:transcribe-api": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-transcribe-api.mjs",
    "test:voice-input-helpers": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-voice-input-helpers.mjs",
    "test:voice-input-recorder": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-voice-input-recorder.mjs",
    "test:voice-input-ui": "node scripts/check-voice-input-ui.mjs",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@lobehub/icons": "^5.6.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "katex": "^0.16.47",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "next": "16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}
